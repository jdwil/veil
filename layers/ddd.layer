pkg ddd v1
  desc "Domain-Driven Design abstraction layer"
  author "VEIL"

  # INV-006: FK / identity conventions (opt-in; off without this block)
  identity_policy
    ref_suffix _id
    identity_field id

  construct Context
    kw ctx
    mt mod
    au
    desc "A bounded context — autonomous domain boundary"
    cst
      requires_groups domain, application, infrastructure, presentation
    visual
      icon "📦"
      color "#8b5cf6"
      label "Bounded Context"
    in top
    # IDE views (docs/PRESENTATION.md) — construct names, not keywords
    present
      view groups
        label "Layers"
        layout tabs
        members by_source_group
        tabs domain, application, infrastructure, presentation
        default
      view model
        label "Domain model"
        layout tree
        members by_host_children
        roots Aggregate
        nest Entity under Aggregate when declared_in_parent
        nest ValueObject under Aggregate when declared_in_parent
        nest Event under Aggregate when declared_in_parent
        nest Command under Aggregate when declared_in_parent
        orphan_policy list

  construct Orchestrator
    kw orchestrator
    mt mod
    desc "Orchestrator — dedicated container for cross-context sagas"
    cst
      only Saga
      requires_groups domain, application, infrastructure, presentation
    visual
      icon "🎯"
      color "#dc2626"
      label "Orchestrator"
    in top
    present
      view groups
        label "Layers"
        layout tabs
        members by_source_group
        tabs domain, application, infrastructure, presentation
        default

  construct Aggregate
    kw agg
    mt struct
    in Context
    desc "Aggregate root — consistency boundary with state, events, and commands"
    has
      root: struct
      state: enum
      fn[]
      Event[]
      Command[]
    cst
      must_have root
      has_identity id
      mutations_through_methods
    visual
      icon "🧩"
      color "#ec4899"
      label "Aggregate"
    ann
      invariant: "Domain constraint validation" expr
    group domain
    present
      role container
      nestable_in model as root

  construct Entity
    kw ent
    mt struct
    in Context
    desc "Entity — domain object with identity"
    cst
      has_identity id
      deny_calls Bus
    visual
      icon "🔑"
      color "#f43f5e"
      label "Entity"
    group domain
    present
      role leaf
      nestable_in model under Aggregate

  construct ValueObject
    kw val
    mt struct
    in Context
    desc "Value Object — immutable, identity-less domain concept"
    cst
      no_identity
      equality_by_value
      deny_calls trait
    visual
      icon "💎"
      color "#14b8a6"
      label "Value Object"
    ann
      invariant: "Validation rule" expr
    group domain
    present
      role leaf
      nestable_in model under Aggregate

  construct Event
    kw evt
    mt struct
    desc "Domain Event — something that happened in the domain"
    cst
      immutable
    visual
      icon "⚡"
      color "#f59e0b"
      label "Domain Event"
    group domain
    in Aggregate
    present
      role leaf
      nestable_in model under Aggregate
      lens critical

  construct Command
    kw cmd
    mt struct
    desc "Command — intent to change domain state"
    visual
      icon "📨"
      color "#3b82f6"
      label "Command"
    ann
      idempotent: "Command is idempotent"
      validate: "Run validation before execution" expr
    group domain
    in Aggregate
    present
      role leaf
      nestable_in model under Aggregate

  construct Query
    kw qry
    mt struct
    desc "Query — request for data, no side effects"
    visual
      icon "🔍"
      color "#06b6d4"
      label "Query"
    group domain

  construct Port
    kw port
    mt trait
    in Context
    desc "Port — interface contract for external dependencies"
    cst
      requires_implementation
    visual
      icon "🔌"
      color "#10b981"
      label "Port"
    group domain
    present
      role leaf
      lens integration
      lens critical

  construct Adapter
    kw adapter
    mt impl
    in Context
    desc "Adapter — implementation of a port for a specific technology"
    cst
      must_implement_port
    visual
      icon "🔗"
      color "#a855f7"
      label "Adapter"
    ann
      env: "Required environment variables" vars
    group infrastructure
    tgt Port, Repository
    dg infrastructure
    present
      role leaf
      lens integration
      lens critical

  construct Repository
    kw repo
    mt trait
    in Context
    desc "Repository — persistence interface for an aggregate"
    cst
      crud_for_aggregate
      requires_implementation
    visual
      icon "🗄️"
      color "#10b981"
      label "Repository"
    group domain

  construct DomainService
    kw svc
    mt fn
    in Context
    desc "Domain Service — orchestrates operations across aggregates within a context"
    visual
      icon "🖥️"
      color "#0ea5e9"
      label "Domain Service"
    ann
      trace: "Add distributed tracing" method
      timeout: "Service-level timeout" ms
    group domain

  construct ApplicationService
    kw handler
    mt fn
    in Context
    desc "Application Service — use case handler that orchestrates domain objects to fulfill commands"
    visual
      icon "📡"
      color "#6366f1"
      label "Application Service"
    ann
      trace: "Add distributed tracing" method
      timeout: "Service-level timeout" ms
    group application

  construct Saga
    kw saga
    mt fn
    desc "Saga — cross-context orchestration with compensation semantics"
    cst
      steps_have_compensation
      spans_contexts
    visual
      icon "🔄"
      color "#dc2626"
      label "Saga"
    ann
      trace: "Add distributed tracing" method
      timeout: "Overall saga timeout" ms
    # Steps are NOT inlined: each is lowered to an `impl SagaStep` and handed to
    # the `run_saga` coordinator (declared below). The main step body fills
    # `action`; the `compensate` sub-block fills `compensate`.
    runtime run_saga SagaStep
      compensate -> compensate
    in Orchestrator
    present
      role container
      lens critical
      lens integration

  # Statement extensions (built on top of core statement shapes)
  statement emit
    mt call
    desc "Emit a domain event from within an aggregate"
    sem domain_event_emit
    visual
      icon "⚡"
      color "#f59e0b"
      label "Emit"

  statement dispatch
    mt Bus.dispatch
    desc "Fire event through event bus (fire-and-forget, multiple handlers)"
    sem event_bus_fire_and_forget
    visual
      icon "📡"
      color "#f59e0b"
      label "Dispatch"

  statement invoke
    mt Bus.invoke
    desc "Execute command through command bus (single handler)"
    sem command_bus_handler
    visual
      icon "⚙️"
      color "#3b82f6"
      label "Invoke"

  statement request
    mt Bus.request
    desc "Query data from another context (inter-context communication)"
    sem inter_context_query
    visual
      icon "🔌"
      color "#10b981"
      label "Request"

  statement guard
    mt if
    desc "Precondition check — fails the step if condition is false"
    sem precondition_fail_step
    visual
      icon "🛡️"
      color "#ef4444"
      label "Guard"

  # ─── LLM Prompt (RAG context for code-generating agents) ─────────────────────
  prompt
    You are writing code using the DDD (Domain-Driven Design) layer for VEIL.

    ## Structure
    Every pkg using `use ddd` organizes code into bounded contexts (`ctx`), each
    containing groups: `domain`, `application`, `infrastructure`, and optionally
    `presentation`.

    ## IDE views (presentation)
    Drilling into a `ctx` offers two views (layer-declared, not hardcoded):
    - **Layers** — tabs for domain / application / infrastructure / presentation
    - **Domain model** — Aggregates as roots; nest `evt`/`cmd` (and `ent`/`val`
      when placed under the aggregate in source) under their owning Aggregate.
      Domain types sitting only under `group domain` appear as top-level orphans
      in the model view. Prefer nesting events and commands under the aggregate
      they belong to for the best model-tree review experience.

    ## Domain Group
    Contains the pure domain model:
    - `agg` (Aggregate) — the consistency boundary. Has a `root` block with fields,
      optional `state` (enum with transitions), `evt` (domain events), and `fn` methods.
    - `ent` (Entity) — subordinate to an aggregate, has identity (id field).
    - `val` (ValueObject) — immutable, identity-less. Use `@invariant(expr)` for validation.
    - `repo` (Repository/Port) — trait interface for persistence. Methods use `!` suffix
      for async operations: `find!(id: Id) -> Opt<T>`, `save!(entity: T)`, `delete!(id: Id)`.

    ## Application Group
    Contains orchestration:
    - `handler` (ApplicationService) — receives commands/queries. Inputs use `@dep` annotation
      to declare injected dependencies (repos, services). Body contains `step` blocks.
    - Steps contain expressions: assignments, repo calls, `guard(condition, "message")` for
      preconditions, and `ret value` to return data.

    ## Infrastructure Group
    Contains adapter implementations:
    - `adapter PgFooRepo for FooRepo` — implements a port with concrete code.
      Annotate with `@env(DATABASE_URL)` to declare required config.
      Each `impl method(params)` contains the body (e.g., SQL via sqlx DSL).

    ## Key Patterns
    - Dependencies are always injected via `@dep` — never construct adapters in handlers.
    - Repos return `Opt<T>` for single lookups, `List<T>` for collections.
    - Use `guard(expr, "msg")` for precondition checks — it short-circuits with a validation error.
    - Use `ret variable` to return query results from handlers.
    - Cross-context communication uses `dispatch`, `invoke`, or `request` (routed via Bus).
    - Sagas use the `saga` keyword with `step`/`compensate` blocks for distributed transactions.

    ## Example Handler
    ```
    handler HandleGetCohort
      input
        id: Id
        @dep cohort_repo: CohortRepo
      step query
        cohort = cohort_repo.find!(id)
        ret cohort
    ```

    ## Example Adapter
    ```
    adapter PgCohortRepo for CohortRepo
      @env(DATABASE_URL)
      impl find(id)
        sqlx.Query.new("SELECT * FROM cohorts WHERE id = $1").bind(id).fetch_optional!(pool)
      impl save(cohort)
        sqlx.Query.new("INSERT INTO cohorts (id) VALUES ($1) ON CONFLICT (id) DO UPDATE SET updated_on = now()").bind(cohort.id).execute!(pool)
    ```

  # ─── Declared constructs (injected into every solution using this layer) ─────
  # The Bus is a JSON message bus: cross-context payloads/results are `Json`
  # (serde_json::Value) so orchestrators can build commands and index results
  # without depending on another context's concrete types.
  declare
    trait Bus
      dispatch(evt: Json) -> Res!
      invoke(cmd: Json) -> Res!<Json>
      request(qry: Json) -> Res!<Json>

    # ─── Auth service (runtime-injected authentication & authorization) ─────
    # The runtime provides the concrete implementation: Cognito, Auth0, custom
    # RBAC, or a BusAuthAdapter that delegates to a VEIL-authored auth context.
    # Domain code calls these methods via the Deps struct like any other port.
    # @strategy selects the runtime adapter (e.g. cognito, auth0, bus).
    @strategy(bus)
    trait AuthService
      validate_token(token: Str) -> Res!<Principal>
      check_permission(principal: Principal, permission: Str) -> Res!<Bool>

    struct Principal
      id: Str
      roles: List<Str>
      claims: Map<Str, Str>

    # ─── Saga runtime (the transactional coordinator), written in VEIL ─────
    # A saga step is a unit of work with a compensating action. Steps share a
    # JSON `state`: each `action` reads prior results from it and returns the
    # updated state, so later steps see earlier results. `run_saga` threads the
    # state forward and, on the first failure, replays the completed steps'
    # compensations in reverse. All ordinary VEIL over the Bus — the engine has
    # no saga knowledge.
    trait SagaStep
      action(bus: Bus, state: Json) -> Res!<Json>
      compensate(bus: Bus, state: Json) -> Res!

    # Replay compensations for the first `upto` steps, most-recent first.
    fn unwind(bus: Bus, steps: List<SagaStep>, upto: Int, state: Json) -> Res!
      mut i = upto
      while i > 0
        i = i - 1
        call steps.get(i).compensate(bus, state)
      ret Ok

    # Run steps forward, threading state; on failure, unwind and propagate.
    fn run_saga(bus: Bus, steps: List<SagaStep>) -> Res!
      mut state = {}
      mut i = 0
      while i < steps.len()
        match call steps.get(i).action(bus, state)
          Ok next ->
            state = next
            i = i + 1
          Err e ->
            call unwind(bus, steps, i, state)
            ret Err(e)
      ret Ok

