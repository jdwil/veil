{
  "context": "Identity",
  "crate": "identity",
  "deps": {
    "auth_service": {
      "provided_by": "runtime",
      "strategy": "bus",
      "trait": "AuthService"
    },
    "bus": {
      "provided_by": "runtime",
      "trait": "Bus"
    },
    "customer_repo": {
      "trait": "CustomerRepo"
    },
    "k_y_c_provider": {
      "trait": "KYCProvider"
    },
    "notifier": {
      "adapter": "SmsTwilio",
      "env": [
        "TWILIO_SID",
        "TWILIO_TOKEN"
      ],
      "trait": "Notifier"
    },
    "saga_step": {
      "provided_by": "runtime",
      "trait": "SagaStep"
    }
  },
  "expose": [],
  "handlers": {
    "CreateCustomerService": {
      "function": "create_customer_service",
      "inputs": [
        {
          "name": "email",
          "type": "Named(\"Email\")"
        },
        {
          "name": "phone",
          "type": "Named(\"Phone\")"
        }
      ]
    }
  }
}