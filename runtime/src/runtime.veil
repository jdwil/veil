sol VeilRuntime
  use ddd
  use aws_storage
  use rig
  use transports
  use axum
  use gix
  use tempfile
  use schemars
  use sha2
  use zip

  # ═══════════════════════════════════════════════════════════════════════════
  # Storage — VCS, Registry, Compiler, Deployer
  # ═══════════════════════════════════════════════════════════════════════════

  ctx Storage
    group domain
      # ─── Identifiers ────────────────────────────────────────────────────
      val RepoId
        value: Str

      val ArtifactId
        value: Str

      val LayerId
        value: Str

      val StubId
        value: Str

      # ─── Enums ──────────────────────────────────────────────────────────
      enum CompilationTarget
        LinuxX86_64
        LinuxAarch64

      enum DeployTarget
        Lambda
          function_name: Str
          region: Str
        Container
          repository_uri: Str
          tag: Str

      enum DeploymentStatus
        InProgress
        Succeeded
        Failed
          reason: Str

      enum ChangeType
        Added
        Modified
        Deleted
        Renamed
          from: Str

      enum DependencyKind
        Layer
        Stub
        Repo

      # ─── Domain Types ───────────────────────────────────────────────────
      agg Repo
        root
          id: RepoId
          name: Str
          description: Opt<Str>
          default_branch: Str
          created_at: Dt
          updated_at: Dt

      val BranchInfo
        name: Str
        head_commit: Str
        updated_at: Dt

      val TagInfo
        name: Str
        commit: Str
        message: Opt<Str>
        created_at: Dt

      val CommitInfo
        hash: Str
        message: Str
        author: Str
        timestamp: Dt
        parent_hashes: List<Str>
        files_changed: List<Str>

      val DiffEntry
        path: Str
        change_type: ChangeType
        old_content: Opt<Str>
        new_content: Opt<Str>

      ent ArtifactMetadata
        id: ArtifactId
        repo_id: RepoId
        branch: Str
        commit_hash: Str
        content_hash: Str
        target: CompilationTarget
        s3_key: Str
        size_bytes: Int
        compiled_at: Dt

      val DeploymentRecord
        artifact_id: ArtifactId
        target: DeployTarget
        deployed_at: Dt
        status: DeploymentStatus

      ent LayerMetadata
        id: LayerId
        name: Str
        repo_id: RepoId
        versions: List<Str>
        latest_version: Opt<Str>
        registered_at: Dt

      ent StubMetadata
        id: StubId
        name: Str
        crate_name: Str
        version: Str
        registered_at: Dt

      val DependencyEdge
        dependent: RepoId
        dependency: Str
        kind: DependencyKind

      # ─── Ports ──────────────────────────────────────────────────────────
      port ObjectStorage
        put!(key: Str, data: Bytes)
        get!(key: Str) -> Bytes
        delete!(key: Str)
        exists!(key: Str) -> Bool
        list!(prefix: Str) -> List<Str>
        size!(key: Str) -> Int

      port MetadataStore
        # Repos
        create_repo!(metadata: Repo)
        get_repo!(id: RepoId) -> Repo
        list_repos!() -> List<Repo>
        delete_repo!(id: RepoId)
        # Branches
        put_branch!(repo_id: RepoId, branch: BranchInfo)
        get_branch!(repo_id: RepoId, name: Str) -> BranchInfo
        list_branches!(repo_id: RepoId) -> List<BranchInfo>
        delete_branch!(repo_id: RepoId, name: Str)
        # Tags
        put_tag!(repo_id: RepoId, tag: TagInfo)
        get_tag!(repo_id: RepoId, name: Str) -> TagInfo
        list_tags!(repo_id: RepoId) -> List<TagInfo>
        delete_tag!(repo_id: RepoId, name: Str)
        # Commits
        put_commit!(repo_id: RepoId, commit: CommitInfo)
        list_commits!(repo_id: RepoId, branch: Opt<Str>, limit: Int, offset: Int) -> List<CommitInfo>
        file_history!(repo_id: RepoId, path: Str, limit: Int) -> List<CommitInfo>
        # Artifacts
        put_artifact!(artifact: ArtifactMetadata)
        get_artifact!(id: ArtifactId) -> ArtifactMetadata
        find_artifact_by_hash!(content_hash: Str, target: CompilationTarget) -> Opt<ArtifactMetadata>
        list_artifacts!(repo_id: RepoId, branch: Opt<Str>) -> List<ArtifactMetadata>
        # Deployments
        put_deployment!(record: DeploymentRecord)
        list_deployments!(artifact_id: ArtifactId) -> List<DeploymentRecord>
        # Layers
        put_layer!(layer: LayerMetadata)
        get_layer!(name: Str) -> LayerMetadata
        list_layers!() -> List<LayerMetadata>
        # Stubs
        put_stub!(stub: StubMetadata)
        get_stub!(crate_name: Str) -> StubMetadata
        list_stubs!() -> List<StubMetadata>
        # Dependencies
        put_dependency!(edge: DependencyEdge)
        get_dependencies!(repo_id: RepoId) -> List<DependencyEdge>
        get_dependents!(dependency: Str) -> List<DependencyEdge>

    group application
      svc CreateRepo
        -> Repo
        input
          name: Str
          description: Opt<Str>
        step execute
          id = RepoId{value: Uuid.new_v4().to_string()}
          now = Dt.now()
          repo = Repo{id, name, description, default_branch: "main", created_at: now, updated_at: now}
          MetadataStore.create_repo!(repo)
          branch = BranchInfo{name: "main", head_commit: "", updated_at: now}
          MetadataStore.put_branch!(id, branch)
          ret repo

      svc ListRepos
        -> List<Repo>
        step query
          repos = MetadataStore.list_repos!()
          ret repos

      svc WriteFile
        -> CommitInfo
        input
          repo_id: RepoId
          branch: Str
          path: Str
          content: Str
          message: Str
        step execute
          key = f"repos/{repo_id.value}/{branch}/{path}"
          hash = content.len().to_string()
          ObjectStorage.put!(key, content.into_bytes())
          now = Dt.now()
          commit = CommitInfo{hash, message, author: "system", timestamp: now, parent_hashes: [], files_changed: [path]}
          MetadataStore.put_commit!(repo_id, commit)
          ret commit

      svc ReadFile
        -> Bytes
        input
          repo_id: RepoId
          branch: Str
          path: Str
        step query
          key = f"repos/{repo_id.value}/{branch}/{path}"
          data = ObjectStorage.get!(key)
          ret data

      svc ListFiles
        -> List<Str>
        input
          repo_id: RepoId
          branch: Str
          prefix: Str
        step query
          key_prefix = f"repos/{repo_id.value}/{branch}/{prefix}"
          files = ObjectStorage.list!(key_prefix)
          ret files

      svc CreateBranch
        -> BranchInfo
        input
          repo_id: RepoId
          name: Str
          from_ref: Str
        step execute
          source = MetadataStore.get_branch!(repo_id, from_ref)
          now = Dt.now()
          branch = BranchInfo{name, head_commit: source.head_commit, updated_at: now}
          MetadataStore.put_branch!(repo_id, branch)
          ret branch

      svc ListBranches
        -> List<BranchInfo>
        input
          repo_id: RepoId
        step query
          branches = MetadataStore.list_branches!(repo_id)
          ret branches

      svc GetDiff
        -> List<DiffEntry>
        input
          repo_id: RepoId
          from_ref: Str
          to_ref: Str
        step query
          # Diff is computed by comparing file trees between refs
          from_files = ObjectStorage.list!(f"repos/{repo_id.value}/{from_ref}/")
          to_files = ObjectStorage.list!(f"repos/{repo_id.value}/{to_ref}/")
          ret []

      svc Compile
        -> ArtifactMetadata
        input
          repo_id: RepoId
          branch: Str
          target: CompilationTarget
        step execute
          branch_info = MetadataStore.get_branch!(repo_id, branch)
          hash = branch_info.head_commit
          id = ArtifactId{value: hash}
          now = Dt.now()
          s3_key = f"artifacts/{hash}/binary"
          artifact = ArtifactMetadata{id, repo_id, branch, commit_hash: hash, content_hash: hash, target, s3_key, size_bytes: 0, compiled_at: now}
          MetadataStore.put_artifact!(artifact)
          ret artifact

      svc Deploy
        -> DeploymentRecord
        input
          artifact_id: ArtifactId
          target: DeployTarget
        step execute
          now = Dt.now()
          record = DeploymentRecord{artifact_id, target, deployed_at: now, status: DeploymentStatus.InProgress}
          MetadataStore.put_deployment!(record)
          ret record

      svc GetCommitLog
        -> List<CommitInfo>
        input
          repo_id: RepoId
          branch: Opt<Str>
          limit: Int
          offset: Int
        step query
          commits = MetadataStore.list_commits!(repo_id, branch, limit, offset)
          ret commits

    group infrastructure
      adapter S3ObjectStorage for ObjectStorage
        @env(AWS_REGION, BUCKET)
        impl put(key, data)
          s3_put_object(bucket, key, data)
        impl get(key)
          s3_get_object(bucket, key)
        impl delete(key)
          s3_delete_object(bucket, key)
        impl exists(key)
          s3_head_object(bucket, key)
        impl list(prefix)
          s3_list_objects(bucket, prefix)
        impl size(key)
          s3_head_object(bucket, key)

      adapter DdbMetadataStore for MetadataStore
        @env(AWS_REGION, DDB_TABLE)
        impl create_repo(metadata)
          ddb_client.put_item(table, metadata)
        impl get_repo(id)
          ddb_client.get_item(table, {pk: f"REPO#{id.value}", sk: "META"})
        impl list_repos()
          ddb_client.query_items(table, {pk_prefix: "REPO#"})
        impl delete_repo(id)
          ddb_client.delete_item(table, {pk: f"REPO#{id.value}", sk: "META"})
        impl put_branch(repo_id, branch)
          ddb_client.put_item(table, {pk: f"REPO#{repo_id.value}", sk: f"BRANCH#{branch.name}"})
        impl get_branch(repo_id, name)
          ddb_client.get_item(table, {pk: f"REPO#{repo_id.value}", sk: f"BRANCH#{name}"})
        impl list_branches(repo_id)
          ddb_client.query_items(table, {pk: f"REPO#{repo_id.value}", sk_prefix: "BRANCH#"})
        impl delete_branch(repo_id, name)
          ddb_client.delete_item(table, {pk: f"REPO#{repo_id.value}", sk: f"BRANCH#{name}"})
        impl put_tag(repo_id, tag)
          ddb_client.put_item(table, {pk: f"REPO#{repo_id.value}", sk: f"TAG#{tag.name}"})
        impl get_tag(repo_id, name)
          ddb_client.get_item(table, {pk: f"REPO#{repo_id.value}", sk: f"TAG#{name}"})
        impl list_tags(repo_id)
          ddb_client.query_items(table, {pk: f"REPO#{repo_id.value}", sk_prefix: "TAG#"})
        impl delete_tag(repo_id, name)
          ddb_client.delete_item(table, {pk: f"REPO#{repo_id.value}", sk: f"TAG#{name}"})
        impl put_commit(repo_id, commit)
          ddb_client.put_item(table, {pk: f"REPO#{repo_id.value}", sk: f"COMMIT#{commit.hash}"})
        impl list_commits(repo_id, branch, limit, offset)
          ddb_client.query_items(table, {pk: f"REPO#{repo_id.value}", sk_prefix: "COMMIT#", limit, offset})
        impl file_history(repo_id, path, limit)
          ddb_client.query_items(table, {pk: f"REPO#{repo_id.value}", sk_prefix: f"FILE#{path}", limit})
        impl put_artifact(artifact)
          ddb_client.put_item(table, {pk: f"ARTIFACT#{artifact.id.value}", sk: "META"})
        impl get_artifact(id)
          ddb_client.get_item(table, {pk: f"ARTIFACT#{id.value}", sk: "META"})
        impl find_artifact_by_hash(content_hash, target)
          ddb_client.query_items(table, {index: "hash-target", pk: content_hash, sk: target})
        impl list_artifacts(repo_id, branch)
          ddb_client.query_items(table, {pk: f"REPO#{repo_id.value}", sk_prefix: "ARTIFACT#"})
        impl put_deployment(record)
          ddb_client.put_item(table, {pk: f"DEPLOY#{record.artifact_id.value}", sk: f"AT#{record.deployed_at}"})
        impl list_deployments(artifact_id)
          ddb_client.query_items(table, {pk: f"DEPLOY#{artifact_id.value}", sk_prefix: "AT#"})
        impl put_layer(layer)
          ddb_client.put_item(table, {pk: f"LAYER#{layer.name}", sk: "META"})
        impl get_layer(name)
          ddb_client.get_item(table, {pk: f"LAYER#{name}", sk: "META"})
        impl list_layers()
          ddb_client.query_items(table, {pk_prefix: "LAYER#"})
        impl put_stub(stub)
          ddb_client.put_item(table, {pk: f"STUB#{stub.crate_name}", sk: "META"})
        impl get_stub(crate_name)
          ddb_client.get_item(table, {pk: f"STUB#{crate_name}", sk: "META"})
        impl list_stubs()
          ddb_client.query_items(table, {pk_prefix: "STUB#"})
        impl put_dependency(edge)
          ddb_client.put_item(table, {pk: f"DEP#{edge.dependent.value}", sk: f"ON#{edge.dependency}"})
        impl get_dependencies(repo_id)
          ddb_client.query_items(table, {pk: f"DEP#{repo_id.value}", sk_prefix: "ON#"})
        impl get_dependents(dependency)
          ddb_client.query_items(table, {index: "dep-reverse", pk: dependency})

  # ═══════════════════════════════════════════════════════════════════════════
  # Tools — Rig SDK tool definitions for agent-callable operations
  # ═══════════════════════════════════════════════════════════════════════════

  ctx Tools
    group domain
      val CreateRepoArgs
        name: Str
        description: Opt<Str>

      val WriteFileArgs
        repo_id: Str
        branch: Str
        path: Str
        content: Str
        message: Str

      val ReadFileArgs
        repo_id: Str
        branch: Str
        path: Str

      val ListFilesArgs
        repo_id: Str
        branch: Str
        prefix: Opt<Str>

      val CreateBranchArgs
        repo_id: Str
        name: Str
        from_ref: Str

      val ListBranchesArgs
        repo_id: Str

      val DiffArgs
        repo_id: Str
        from_ref: Str
        to_ref: Str

      val CompileArgs
        repo_id: Str
        branch: Str
        target: Str

      val DeployArgs
        artifact_id: Str
        target: Str
        tag: Opt<Str>

      val ListReposArgs

      val LogArgs
        repo_id: Str
        branch: Opt<Str>
        limit: Opt<Int>

    group application
      tool CreateRepoTool
        -> Json
        @desc("Create a new VEIL repository")
        input
          name: Str
          description: Opt<Str>
        step execute
          result = request CreateRepo{name, description}
          ret result

      tool WriteFileTool
        -> Json
        @desc("Write a file to a VEIL repository and commit the change")
        input
          repo_id: Str
          branch: Str
          path: Str
          content: Str
          message: Str
        step execute
          id = repo_id
          result = invoke WriteFile{repo_id: id, branch, path, content, message}
          ret result

      tool ReadFileTool
        -> Json
        @desc("Read a file from a VEIL repository")
        input
          repo_id: Str
          branch: Str
          path: Str
        step execute
          id = repo_id
          result = invoke ReadFile{repo_id: id, branch, path}
          ret {content: result, path}

      tool ListFilesTool
        -> Json
        @desc("List files in a VEIL repository")
        input
          repo_id: Str
          branch: Str
          prefix: Opt<Str>
        step execute
          id = repo_id
          p = prefix.unwrap_or("")
          files = invoke ListFiles{repo_id: id, branch, prefix: p}
          ret {files}

      tool CreateBranchTool
        -> Json
        @desc("Create a new branch in a VEIL repository")
        input
          repo_id: Str
          name: Str
          from_ref: Str
        step execute
          id = repo_id
          branch = invoke CreateBranch{repo_id: id, name, from_ref}
          ret branch

      tool ListBranchesTool
        -> Json
        @desc("List all branches in a VEIL repository")
        input
          repo_id: Str
        step execute
          id = repo_id
          branches = invoke ListBranches{repo_id: id}
          ret branches

      tool DiffTool
        -> Json
        @desc("Get the diff between two refs in a VEIL repository")
        input
          repo_id: Str
          from_ref: Str
          to_ref: Str
        step execute
          id = repo_id
          diff = invoke GetDiff{repo_id: id, from_ref, to_ref}
          ret diff

      tool CompileTool
        -> Json
        @desc("Compile a VEIL project. Produces a binary cached by content hash.")
        input
          repo_id: Str
          branch: Str
          target: Str
        step execute
          id = repo_id
          result = invoke Compile{repo_id: id, branch, target}
          ret result

      tool DeployTool
        -> Json
        @desc("Deploy a compiled VEIL artifact to Lambda or as a container image")
        input
          artifact_id: Str
          target: Str
          tag: Opt<Str>
        step execute
          aid = artifact_id
          result = invoke Deploy{artifact_id: aid, target, tag}
          ret result

      tool ListReposTool
        -> Json
        @desc("List all VEIL repositories")
        step execute
          repos = invoke ListRepos{}
          ret repos

      tool LogTool
        -> Json
        @desc("Get commit history for a VEIL repository")
        input
          repo_id: Str
          branch: Opt<Str>
          limit: Opt<Int>
        step execute
          id = repo_id
          l = limit.unwrap_or(20)
          commits = invoke GetCommitLog{repo_id: id, branch, limit: l, offset: 0}
          ret commits

    group infrastructure

  # ═══════════════════════════════════════════════════════════════════════════
  # Daemon — WebSocket server with agent and direct tool-call modes
  # ═══════════════════════════════════════════════════════════════════════════

  ctx Daemon
    group domain
      val DaemonConfig
        port: Int
        work_dir: Str
        s3_bucket: Opt<Str>
        ddb_table: Opt<Str>
        aws_region: Str
        ecr_repository_prefix: Opt<Str>
        llm_api_key: Opt<Str>
        llm_model: Str

      enum IncomingMessage
        Agent
          message: Str
        Tool
          tool: Str
          args: Json

      enum OutgoingMessage
        Result
          data: Json
        AgentResponse
          message: Str
        Error
          message: Str
          code: Str
        Ack
          id: Opt<Str>

    group application
      svc LoadConfig
        -> DaemonConfig
        step execute
          work_dir = Env.get_or("VEIL_WORK_DIR", "/tmp/veil-runtime")
          s3_bucket = Env.get_opt("VEIL_S3_BUCKET")
          ddb_table = Env.get_opt("VEIL_DDB_TABLE")
          aws_region = Env.get_or("AWS_REGION", "us-east-1")
          ecr_prefix = Env.get_opt("VEIL_ECR_PREFIX")
          llm_api_key = Env.get_opt("OPENAI_API_KEY")
          llm_model = Env.get_or("VEIL_LLM_MODEL", "gpt-4o")
          ret DaemonConfig{port: 8080, work_dir, s3_bucket, ddb_table, aws_region, ecr_repository_prefix: ecr_prefix, llm_api_key, llm_model}

      ws_handler HandleConnection
        @path("/ws")
        input
          msg: Str
        step handle
          # Route message to agent or tool handler via Bus
          response = invoke HandleToolCall{tool: "echo", args: {}}
          send_ws response

      svc HandleAgentMessage
        -> OutgoingMessage
        input
          message: Str
        step execute
          # Placeholder — requires LLM API key
          response = OutgoingMessage.AgentResponse{message: f"Agent mode received: '{message}'. Configure OPENAI_API_KEY to enable."}
          ret response

      svc HandleToolCall
        -> OutgoingMessage
        input
          tool: Str
          args: Json
        step execute
          result = match tool
            "create_repo" -> invoke CreateRepoTool{name: args.name, description: args.description}
            "write_file" -> invoke WriteFileTool{repo_id: args.repo_id, branch: args.branch, path: args.path, content: args.content, message: args.message}
            "read_file" -> invoke ReadFileTool{repo_id: args.repo_id, branch: args.branch, path: args.path}
            "list_files" -> invoke ListFilesTool{repo_id: args.repo_id, branch: args.branch, prefix: args.prefix}
            "create_branch" -> invoke CreateBranchTool{repo_id: args.repo_id, name: args.name, from_ref: args.from_ref}
            "list_branches" -> invoke ListBranchesTool{repo_id: args.repo_id}
            "diff" -> invoke DiffTool{repo_id: args.repo_id, from_ref: args.from_ref, to_ref: args.to_ref}
            "compile" -> invoke CompileTool{repo_id: args.repo_id, branch: args.branch, target: args.target}
            "deploy" -> invoke DeployTool{artifact_id: args.artifact_id, target: args.target, tag: args.tag}
            "list_repos" -> invoke ListReposTool{}
            "log" -> invoke LogTool{repo_id: args.repo_id, branch: args.branch, limit: args.limit}
            _ -> ret OutgoingMessage.Error{message: f"unknown tool: {tool}", code: "UNKNOWN_TOOL"}
          ret OutgoingMessage.Result{data: result}

      http_route HealthCheck
        -> Json
        @method("GET")
        @path("/health")
        step handle
          ret {status: "healthy", service: "veil-runtime"}

    group infrastructure

  # ═══════════════════════════════════════════════════════════════════════════
  # Exec — Application harness, Bus implementations, wiring, auth, security
  # ═══════════════════════════════════════════════════════════════════════════

  ctx Exec
    group domain
      # ─── Bus & Handler Types ────────────────────────────────────────────
      port Handler
        handle!(payload: Str) -> Str

      # ─── Manifest Types ─────────────────────────────────────────────────
      val Dependency
        trait_name: Str
        adapter: Opt<Str>
        provided_by: Opt<Str>
        env: List<Str>

      val HandlerInput
        name: Str
        type_desc: Str

      val HandlerDef
        function: Str
        inputs: List<HandlerInput>

      val Manifest
        context: Str
        crate_name: Str
        deps: Map<Str, Dependency>
        handlers: Map<Str, HandlerDef>

      # ─── Auth Types ─────────────────────────────────────────────────────
      ent Principal
        id: Str
        roles: List<Str>
        claims: Map<Str, Str>

      enum AuthStrategy
        Bus
        External
          provider_url: Str
          client_id: Str

      port AuthService
        validate_token!(token: Str) -> Principal
        check_permission!(principal: Principal, action: Str, resource: Str) -> Bool

      # ─── Security Types ─────────────────────────────────────────────────
      enum Severity
        Info
        Warning
        Error
        Critical

      val ScanFinding
        scanner: Str
        severity: Severity
        message: Str
        location: Opt<Str>
        rule_id: Opt<Str>

      val ScanReport
        scanned_at: Dt
        passed: Bool
        findings: List<ScanFinding>
        summary: Map<Str, Int>

      val ScanConfig
        fail_threshold: Severity
        skip_clippy: Bool
        skip_audit: Bool
        skip_deny: Bool
        custom_rules: List<Str>

      # ─── Wiring Types ───────────────────────────────────────────────────
      val EnvConfig
        vars: Map<Str, Str>

      port HandlerFactory
        create_handler!(message_name: Str, env: EnvConfig) -> Opt<Json>
        context_name!() -> Str

    group application
      svc ParseManifest
        -> Manifest
        input
          json: Str
        step execute
          ret Manifest{context: json, crate_name: "unknown", deps: Map.new(), handlers: Map.new()}

      svc ReadAllManifests
        -> List<Manifest>
        input
          workspace_dir: Str
        step execute
          ret []

      svc LoadEnvConfig
        -> EnvConfig
        input
          manifests: List<Manifest>
        step execute
          # Load required env vars from manifests, fail if any missing
          vars = {}
          ret EnvConfig{vars: Map.new()}

      svc WireApplication
        -> List<Str>
        input
          manifests: List<Manifest>
          env: EnvConfig
        step execute
          # Wire handlers from manifests using registered factories
          ret []

      svc RunSecurityScan
        -> ScanReport
        input
          workspace_dir: Str
          config: ScanConfig
        step execute
          mut findings = []
          # Run security scans (clippy, audit, deny)
          # Implementation delegates to external scan runners
          now = Dt.now()
          passed = findings.is_empty()
          ret ScanReport{scanned_at: now, passed, findings, summary: Map.new()}

      svc StartHarness
        -> Json
        input
          port: Int
        step execute
          # Build HTTP router with bus endpoints and start listening
          ret {port, status: "running"}

    group infrastructure
      adapter BusAuthAdapter for AuthService
        impl validate_token(token)
          ret Principal{id: token, roles: [], claims: Map.new()}
        impl check_permission(principal, action, resource)
          ret true
