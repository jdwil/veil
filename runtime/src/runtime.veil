pkg VeilRuntime
  use ddd
  use aws_storage
  use rig
  use transports
  use axum
  use gix
  use tempfile
  use schemars
  use sha2
  use zip
  use aws_sdk_s3 as s3
  use aws_sdk_dynamodb as ddb
  use aws_config as cfg
  # Local FS facade (other Storage adapters). Extensions use veil_ext_store.
  use veil_local_fs
  # Extension registry/source/artifacts — file|AWS switch lives in the crate, not SDK lowering
  use veil_ext_store

  # ═══════════════════════════════════════════════════════════════════════════
  # Storage — VCS, Registry, Compiler, Deployer
  # ═══════════════════════════════════════════════════════════════════════════

  ctx Storage
    group domain
      # ─── Identifiers ────────────────────────────────────────────────────
      val RepoId
        value: Str

      val ArtifactId
        value: Str

      val LayerId
        value: Str

      val StubId
        value: Str

      # ─── Enums ──────────────────────────────────────────────────────────
      enum CompilationTarget
        LinuxX86_64
        LinuxAarch64

      enum DeployTarget
        Lambda
          function_name: Str
          region: Str
        Container
          repository_uri: Str
          tag: Str

      enum DeploymentStatus
        InProgress
        Succeeded
        Failed
          reason: Str

      enum ChangeType
        Added
        Modified
        Deleted
        Renamed
          from: Str

      enum DependencyKind
        Layer
        Stub
        Repo

      # ─── Domain Types ───────────────────────────────────────────────────
      agg Repo
        root
          id: RepoId
          name: Str
          description: Opt<Str>
          default_branch: Str
          created_at: Dt
          updated_at: Dt

      val BranchInfo
        name: Str
        head_commit: Str
        updated_at: Dt

      val TagInfo
        name: Str
        commit: Str
        message: Opt<Str>
        created_at: Dt

      val CommitInfo
        hash: Str
        message: Str
        author: Str
        timestamp: Dt
        parent_hashes: List<Str>
        files_changed: List<Str>

      val DiffEntry
        path: Str
        change_type: ChangeType
        old_content: Opt<Str>
        new_content: Opt<Str>

      ent ArtifactMetadata
        id: ArtifactId
        repo_id: RepoId
        branch: Str
        commit_hash: Str
        content_hash: Str
        target: CompilationTarget
        s3_key: Str
        size_bytes: Int
        compiled_at: Dt

      val DeploymentRecord
        artifact_id: ArtifactId
        target: DeployTarget
        deployed_at: Dt
        status: DeploymentStatus

      ent LayerMetadata
        id: LayerId
        name: Str
        repo_id: RepoId
        versions: List<Str>
        latest_version: Opt<Str>
        registered_at: Dt

      ent StubMetadata
        id: StubId
        name: Str
        crate_name: Str
        version: Str
        registered_at: Dt

      val DependencyEdge
        dependent: RepoId
        dependency: Str
        kind: DependencyKind

      # ─── Ports ──────────────────────────────────────────────────────────
      port ObjectStorage
        put!(key: Str, data: Bytes)
        get!(key: Str) -> Bytes
        delete!(key: Str)
        exists!(key: Str) -> Bool
        list!(prefix: Str) -> List<Str>
        size!(key: Str) -> Int

      port MetadataStore
        # Repos
        create_repo!(metadata: Repo)
        get_repo!(id: RepoId) -> Repo
        list_repos!() -> List<Repo>
        delete_repo!(id: RepoId)
        # Branches
        put_branch!(repo_id: RepoId, branch: BranchInfo)
        get_branch!(repo_id: RepoId, name: Str) -> BranchInfo
        list_branches!(repo_id: RepoId) -> List<BranchInfo>
        delete_branch!(repo_id: RepoId, name: Str)
        # Tags
        put_tag!(repo_id: RepoId, tag: TagInfo)
        get_tag!(repo_id: RepoId, name: Str) -> TagInfo
        list_tags!(repo_id: RepoId) -> List<TagInfo>
        delete_tag!(repo_id: RepoId, name: Str)
        # Commits
        put_commit!(repo_id: RepoId, commit: CommitInfo)
        list_commits!(repo_id: RepoId, branch: Opt<Str>, limit: Int, offset: Int) -> List<CommitInfo>
        file_history!(repo_id: RepoId, path: Str, limit: Int) -> List<CommitInfo>
        # Artifacts
        put_artifact!(artifact: ArtifactMetadata)
        get_artifact!(id: ArtifactId) -> ArtifactMetadata
        find_artifact_by_hash!(content_hash: Str, target: CompilationTarget) -> Opt<ArtifactMetadata>
        list_artifacts!(repo_id: RepoId, branch: Opt<Str>) -> List<ArtifactMetadata>
        # Deployments
        put_deployment!(record: DeploymentRecord)
        list_deployments!(artifact_id: ArtifactId) -> List<DeploymentRecord>
        # Layers
        put_layer!(layer: LayerMetadata)
        get_layer!(name: Str) -> LayerMetadata
        list_layers!() -> List<LayerMetadata>
        # Stubs
        put_stub!(stub: StubMetadata)
        get_stub!(crate_name: Str) -> StubMetadata
        list_stubs!() -> List<StubMetadata>
        # Dependencies
        put_dependency!(edge: DependencyEdge)
        get_dependencies!(repo_id: RepoId) -> List<DependencyEdge>
        get_dependents!(dependency: Str) -> List<DependencyEdge>

    group application
      svc CreateRepo
        -> Repo
        input
          name: Str
          description: Opt<Str>
        step execute
          id = RepoId{value: Uuid.new_v4().to_string()}
          now = Dt.now()
          repo = Repo{id, name, description, default_branch: "main", created_at: now, updated_at: now}
          MetadataStore.create_repo!(repo)
          branch = BranchInfo{name: "main", head_commit: "", updated_at: now}
          MetadataStore.put_branch!(id, branch)
          ret repo

      svc ListRepos
        -> List<Repo>
        step query
          repos = MetadataStore.list_repos!()
          ret repos

      svc WriteFile
        -> CommitInfo
        input
          repo_id: RepoId
          branch: Str
          path: Str
          content: Str
          message: Str
        step execute
          key = f"repos/{repo_id.value}/{branch}/{path}"
          hash = content.len().to_string()
          ObjectStorage.put!(key, content.into_bytes())
          now = Dt.now()
          commit = CommitInfo{hash, message, author: "system", timestamp: now, parent_hashes: [], files_changed: [path]}
          MetadataStore.put_commit!(repo_id, commit)
          ret commit

      svc ReadFile
        -> Bytes
        input
          repo_id: RepoId
          branch: Str
          path: Str
        step query
          key = f"repos/{repo_id.value}/{branch}/{path}"
          data = ObjectStorage.get!(key)
          ret data

      svc ListFiles
        -> List<Str>
        input
          repo_id: RepoId
          branch: Str
          prefix: Str
        step query
          key_prefix = f"repos/{repo_id.value}/{branch}/{prefix}"
          files = ObjectStorage.list!(key_prefix)
          ret files

      svc CreateBranch
        -> BranchInfo
        input
          repo_id: RepoId
          name: Str
          from_ref: Str
        step execute
          source = MetadataStore.get_branch!(repo_id, from_ref)
          now = Dt.now()
          branch = BranchInfo{name, head_commit: source.head_commit, updated_at: now}
          MetadataStore.put_branch!(repo_id, branch)
          ret branch

      svc ListBranches
        -> List<BranchInfo>
        input
          repo_id: RepoId
        step query
          branches = MetadataStore.list_branches!(repo_id)
          ret branches

      svc GetDiff
        -> List<DiffEntry>
        input
          repo_id: RepoId
          from_ref: Str
          to_ref: Str
        step query
          # Diff is computed by comparing file trees between refs
          from_files = ObjectStorage.list!(f"repos/{repo_id.value}/{from_ref}/")
          to_files = ObjectStorage.list!(f"repos/{repo_id.value}/{to_ref}/")
          ret []

      svc Compile
        -> ArtifactMetadata
        input
          repo_id: RepoId
          branch: Str
          target: CompilationTarget
        step execute
          branch_info = MetadataStore.get_branch!(repo_id, branch)
          hash = branch_info.head_commit
          id = ArtifactId{value: hash}
          now = Dt.now()
          s3_key = f"artifacts/{hash}/binary"
          artifact = ArtifactMetadata{id, repo_id, branch, commit_hash: hash, content_hash: hash, target, s3_key, size_bytes: 0, compiled_at: now}
          MetadataStore.put_artifact!(artifact)
          ret artifact

      svc Deploy
        -> DeploymentRecord
        input
          artifact_id: ArtifactId
          target: DeployTarget
        step execute
          now = Dt.now()
          record = DeploymentRecord{artifact_id, target, deployed_at: now, status: DeploymentStatus.InProgress}
          MetadataStore.put_deployment!(record)
          ret record

      svc GetCommitLog
        -> List<CommitInfo>
        input
          repo_id: RepoId
          branch: Opt<Str>
          limit: Int
          offset: Int
        step query
          commits = MetadataStore.list_commits!(repo_id, branch, limit, offset)
          ret commits

    group infrastructure
      adapter S3ObjectStorage for ObjectStorage
        @field(client: S3Client)
        @env(BUCKET)
        impl put(key, data)
          S3Client.put_object(bucket, key, data).execute!(client)
        impl get(key)
          S3Client.get_object(bucket, key).fetch_one!(client)
        impl delete(key)
          S3Client.delete_object(bucket, key).execute!(client)
        impl exists(key)
          S3Client.head_object(bucket, key).fetch_one!(client)
        impl list(prefix)
          S3Client.list_objects(bucket, prefix).fetch_all!(client)
        impl size(key)
          S3Client.head_object(bucket, key).fetch_one!(client)
      adapter DdbMetadataStore for MetadataStore
        @field(client: DdbClient)
        @env(TABLE)
        impl create_repo(metadata)
          DdbClient.put_item("repos", metadata).execute!(client)
        impl get_repo(id)
          DdbClient.query("repos").key(id).fetch_one!(client)
        impl list_repos()
          DdbClient.query("repos").fetch_all!(client)
        impl delete_repo(id)
          DdbClient.delete("repos").key(id).execute!(client)
        impl put_branch(repo_id, branch)
          DdbClient.put_item("branches", branch).execute!(client)
        impl get_branch(repo_id, name)
          DdbClient.query("branches").key(name).fetch_one!(client)
        impl list_branches(repo_id)
          DdbClient.query("branches").filter(repo_id).fetch_all!(client)
        impl delete_branch(repo_id, name)
          DdbClient.delete("branches").key(name).execute!(client)
        impl put_tag(repo_id, tag)
          DdbClient.put_item("tags", tag).execute!(client)
        impl get_tag(repo_id, name)
          DdbClient.query("tags").key(name).fetch_one!(client)
        impl list_tags(repo_id)
          DdbClient.query("tags").filter(repo_id).fetch_all!(client)
        impl delete_tag(repo_id, name)
          DdbClient.delete("tags").key(name).execute!(client)
        impl put_commit(repo_id, commit)
          DdbClient.put_item("commits", commit).execute!(client)
        impl list_commits(repo_id, branch, limit, offset)
          DdbClient.query("commits").filter(repo_id).limit(limit).fetch_all!(client)
        impl file_history(repo_id, path, limit)
          DdbClient.query("commits").filter(path).limit(limit).fetch_all!(client)
        impl put_artifact(artifact)
          DdbClient.put_item("artifacts", artifact).execute!(client)
        impl get_artifact(id)
          DdbClient.query("artifacts").key(id).fetch_one!(client)
        impl find_artifact_by_hash(content_hash, target)
          DdbClient.query("artifacts").filter(content_hash).fetch_optional!(client)
        impl list_artifacts(repo_id, branch)
          DdbClient.query("artifacts").filter(repo_id).fetch_all!(client)
        impl put_deployment(record)
          DdbClient.put_item("deployments", record).execute!(client)
        impl list_deployments(artifact_id)
          DdbClient.query("deployments").filter(artifact_id).fetch_all!(client)
        impl put_layer(layer)
          DdbClient.put_item("layers", layer).execute!(client)
        impl get_layer(name)
          DdbClient.query("layers").key(name).fetch_one!(client)
        impl list_layers()
          DdbClient.query("layers").fetch_all!(client)
        impl put_stub(stub)
          DdbClient.put_item("stubs", stub).execute!(client)
        impl get_stub(crate_name)
          DdbClient.query("stubs").key(crate_name).fetch_one!(client)
        impl list_stubs()
          DdbClient.query("stubs").fetch_all!(client)
        impl put_dependency(edge)
          DdbClient.put_item("dependencies", edge).execute!(client)
        impl get_dependencies(repo_id)
          DdbClient.query("dependencies").filter(repo_id).fetch_all!(client)
        impl get_dependents(dependency)
          DdbClient.query("dependencies").filter(dependency).fetch_all!(client)

  # ═══════════════════════════════════════════════════════════════════════════
  # Tools — Rig SDK tool definitions for agent-callable operations
  # ═══════════════════════════════════════════════════════════════════════════

  ctx Tools
    group domain
      val CreateRepoArgs
        name: Str
        description: Opt<Str>

      val WriteFileArgs
        repo_id: Str
        branch: Str
        path: Str
        content: Str
        message: Str

      val ReadFileArgs
        repo_id: Str
        branch: Str
        path: Str

      val ListFilesArgs
        repo_id: Str
        branch: Str
        prefix: Opt<Str>

      val CreateBranchArgs
        repo_id: Str
        name: Str
        from_ref: Str

      val ListBranchesArgs
        repo_id: Str

      val DiffArgs
        repo_id: Str
        from_ref: Str
        to_ref: Str

      val CompileArgs
        repo_id: Str
        branch: Str
        target: Str

      val DeployArgs
        artifact_id: Str
        target: Str
        tag: Opt<Str>

      val ListReposArgs

      val LogArgs
        repo_id: Str
        branch: Opt<Str>
        limit: Opt<Int>

      # EXT-07: agent must validate reaction graph nodes against palette
      val ValidateReactionPaletteArgs
        node_kinds: List<Str>

    group application
      tool CreateRepoTool
        -> Json
        @desc("Create a new VEIL repository")
        input
          name: Str
          description: Opt<Str>
        step execute
          result = request CreateRepo{name, description}
          ret result

      tool WriteFileTool
        -> Json
        @desc("Write a file to a VEIL repository and commit the change")
        input
          repo_id: Str
          branch: Str
          path: Str
          content: Str
          message: Str
        step execute
          id = repo_id
          result = invoke WriteFile{repo_id: id, branch, path, content, message}
          ret result

      tool ReadFileTool
        -> Json
        @desc("Read a file from a VEIL repository")
        input
          repo_id: Str
          branch: Str
          path: Str
        step execute
          id = repo_id
          result = invoke ReadFile{repo_id: id, branch, path}
          ret {content: result, path}

      tool ListFilesTool
        -> Json
        @desc("List files in a VEIL repository")
        input
          repo_id: Str
          branch: Str
          prefix: Opt<Str>
        step execute
          id = repo_id
          p = prefix.unwrap_or("")
          files = invoke ListFiles{repo_id: id, branch, prefix: p}
          ret {files}

      tool CreateBranchTool
        -> Json
        @desc("Create a new branch in a VEIL repository")
        input
          repo_id: Str
          name: Str
          from_ref: Str
        step execute
          id = repo_id
          branch = invoke CreateBranch{repo_id: id, name, from_ref}
          ret branch

      tool ListBranchesTool
        -> Json
        @desc("List all branches in a VEIL repository")
        input
          repo_id: Str
        step execute
          id = repo_id
          branches = invoke ListBranches{repo_id: id}
          ret branches

      tool DiffTool
        -> Json
        @desc("Get the diff between two refs in a VEIL repository")
        input
          repo_id: Str
          from_ref: Str
          to_ref: Str
        step execute
          id = repo_id
          diff = invoke GetDiff{repo_id: id, from_ref, to_ref}
          ret diff

      tool CompileTool
        -> Json
        @desc("Compile a VEIL project. Produces a binary cached by content hash.")
        input
          repo_id: Str
          branch: Str
          target: Str
        step execute
          id = repo_id
          result = invoke Compile{repo_id: id, branch, target}
          ret result

      tool DeployTool
        -> Json
        @desc("Deploy a compiled VEIL artifact to Lambda or as a container image")
        input
          artifact_id: Str
          target: Str
          tag: Opt<Str>
        step execute
          aid = artifact_id
          result = invoke Deploy{artifact_id: aid, target, tag}
          ret result

      tool ListReposTool
        -> Json
        @desc("List all VEIL repositories")
        step execute
          repos = invoke ListRepos{}
          ret repos

      tool LogTool
        -> Json
        @desc("Get commit history for a VEIL repository")
        input
          repo_id: Str
          branch: Opt<Str>
          limit: Opt<Int>
        step execute
          id = repo_id
          l = limit.unwrap_or(20)
          commits = invoke GetCommitLog{repo_id: id, branch, limit: l, offset: 0}
          ret commits

      # EXT-07: server-side palette gate — agents must call before applying reaction graph edits
      tool ValidateReactionPaletteTool
        -> Json
        @desc("Reject reaction node kinds outside the EXT-05 palette (Guard, Activate, Map, EmitEvent, End). Call before applying any agent-proposed reaction graph. Returns {ok:bool, message:str}.")
        input
          node_kinds: List<Str>
        step execute
          ok = invoke ValidateReactionPalette{node_kinds: node_kinds}
          if ok
            ret {ok: true, message: "palette ok"}
          ret {ok: false, message: "rejected: one or more node kinds are outside the reaction palette (allowed: Guard, Activate, Map, EmitEvent, End)"}

      tool ProposeReactionGraphTool
        -> Json
        @desc("Apply a proposed reaction node list only if ValidateReactionPalette accepts it. Rejects free-form / non-palette constructs.")
        input
          node_kinds: List<Str>
        step execute
          ok = invoke ValidateReactionPalette{node_kinds: node_kinds}
          if ok == false
            ret {ok: false, accepted: false, message: "rejected: graph not presentable with configured palette", node_kinds: node_kinds}
          ret {ok: true, accepted: true, message: "accepted", node_kinds: node_kinds}

    group infrastructure

  # ═══════════════════════════════════════════════════════════════════════════
  # Daemon — WebSocket server with agent and direct tool-call modes
  # ═══════════════════════════════════════════════════════════════════════════

  ctx Daemon
    group domain
      val DaemonConfig
        port: Int
        work_dir: Str
        s3_bucket: Opt<Str>
        ddb_table: Opt<Str>
        aws_region: Str
        ecr_repository_prefix: Opt<Str>
        llm_api_key: Opt<Str>
        llm_model: Str

      enum IncomingMessage
        Agent
          message: Str
        Tool
          tool: Str
          args: Json

      enum OutgoingMessage
        Result
          data: Json
        AgentResponse
          message: Str
        Error
          message: Str
          code: Str
        Ack
          id: Opt<Str>

    group application
      svc LoadConfig
        -> DaemonConfig
        step execute
          work_dir = Env.get_or("VEIL_WORK_DIR", "/tmp/veil-runtime")
          s3_bucket = Env.get_opt("VEIL_S3_BUCKET")
          ddb_table = Env.get_opt("VEIL_DDB_TABLE")
          aws_region = Env.get_or("AWS_REGION", "us-east-1")
          ecr_prefix = Env.get_opt("VEIL_ECR_PREFIX")
          llm_api_key = Env.get_opt("OPENAI_API_KEY")
          llm_model = Env.get_or("VEIL_LLM_MODEL", "gpt-4o")
          ret DaemonConfig{port: 8080, work_dir, s3_bucket, ddb_table, aws_region, ecr_repository_prefix: ecr_prefix, llm_api_key, llm_model}

      ws_handler HandleConnection
        @path("/ws")
        input
          msg: Str
        step handle
          # Route message to agent or tool handler via Bus
          response = invoke HandleToolCall{tool: "echo", args: {}}
          send_ws response

      svc HandleAgentMessage
        -> OutgoingMessage
        input
          message: Str
        step execute
          # Placeholder — requires LLM API key
          response = OutgoingMessage.AgentResponse{message: f"Agent mode received: '{message}'. Configure OPENAI_API_KEY to enable."}
          ret response

      svc HandleToolCall
        -> OutgoingMessage
        input
          tool: Str
          args: Json
        step execute
          result = request HandleTool{tool, args}
          ret OutgoingMessage.Result{data: result}

      http_route HealthCheck
        -> Json
        @method("GET")
        @path("/health")
        step handle
          ret {status: "healthy", service: "veil-runtime"}

    group infrastructure

  # ═══════════════════════════════════════════════════════════════════════════
  # Exec — Application harness, Bus implementations, wiring, auth, security
  # ═══════════════════════════════════════════════════════════════════════════

  ctx Exec
    group domain
      # ─── Bus & Handler Types ────────────────────────────────────────────
      port Handler
        handle!(payload: Str) -> Str

      # ─── Manifest Types ─────────────────────────────────────────────────
      val Dependency
        trait_name: Str
        adapter: Opt<Str>
        provided_by: Opt<Str>
        env: List<Str>

      val HandlerInput
        name: Str
        type_desc: Str

      val HandlerDef
        function: Str
        inputs: List<HandlerInput>

      val Manifest
        context: Str
        crate_name: Str
        deps: Map<Str, Dependency>
        handlers: Map<Str, HandlerDef>

      # ─── Auth Types ─────────────────────────────────────────────────────

      enum AuthStrategy
        Bus
        External
          provider_url: Str
          client_id: Str


      # ─── Security Types ─────────────────────────────────────────────────
      enum Severity
        Info
        Warning
        Error
        Critical

      val ScanFinding
        scanner: Str
        severity: Severity
        message: Str
        location: Opt<Str>
        rule_id: Opt<Str>

      val ScanReport
        scanned_at: Dt
        passed: Bool
        findings: List<ScanFinding>
        summary: Map<Str, Int>

      val ScanConfig
        fail_threshold: Severity
        skip_clippy: Bool
        skip_audit: Bool
        skip_deny: Bool
        custom_rules: List<Str>

      # ─── Wiring Types ───────────────────────────────────────────────────
      val EnvConfig
        vars: Map<Str, Str>

      port HandlerFactory
        create_handler!(message_name: Str, env: EnvConfig) -> Opt<Json>
        context_name!() -> Str

    group application
      svc ParseManifest
        -> Manifest
        input
          json: Str
        step execute
          ret Manifest{context: json, crate_name: "unknown", deps: Map.new(), handlers: Map.new()}

      svc ReadAllManifests
        -> List<Manifest>
        input
          workspace_dir: Str
        step execute
          ret []

      svc LoadEnvConfig
        -> EnvConfig
        input
          manifests: List<Manifest>
        step execute
          # Load required env vars from manifests, fail if any missing
          vars = {}
          ret EnvConfig{vars: Map.new()}

      svc WireApplication
        -> List<Str>
        input
          manifests: List<Manifest>
          env: EnvConfig
        step execute
          # Wire handlers from manifests using registered factories
          ret []

      svc RunSecurityScan
        -> ScanReport
        input
          workspace_dir: Str
          config: ScanConfig
        step execute
          mut findings = []
          # Run security scans (clippy, audit, deny)
          # Implementation delegates to external scan runners
          now = Dt.now()
          passed = findings.is_empty()
          ret ScanReport{scanned_at: now, passed, findings, summary: Map.new()}

      svc StartHarness
        -> Json
        input
          port: Int
        step execute
          # Build HTTP router with bus endpoints and start listening
          ret {port, status: "running"}

    group infrastructure
      adapter BusAuthAdapter for AuthService
        impl validate_token(token)
          ret Principal{id: token, roles: [], claims: Map.new()}
        impl check_permission(principal, action, resource)
          ret true

  # ═══════════════════════════════════════════════════════════════════════════
  # Extensions — registry for mini-programs (Reactions, Signals, UI, …)
  # Design: application/docs/veil-extensions.md · Stories: EXT-02+
  # MUST: VEIL-authored domain/services/handlers; ports + local/AWS adapters.
  # ═══════════════════════════════════════════════════════════════════════════

  ctx Extensions
    group domain
      enum ExtensionScope
        Platform
        Product
        Tenant

      enum ExtensionKind
        Reaction
        Signal
        Activation
        UiPanel

      enum ExtensionProvenance
        Stock
        Custom

      # Lineage for duplicate-as-custom (EXT-09)
      val ExtensionLineage
        extension_id: Id
        version: Int

      # Registry row (meta). Source/artifacts live behind source/artifact ports.
      val ExtensionRecord
        extension_id: Id
        scope: ExtensionScope
        product_id: Opt<Str>
        tenant_id: Opt<Id>
        initiative_id: Opt<Id>
        kind: ExtensionKind
        provenance: ExtensionProvenance
        name: Str
        description: Opt<Str>
        current_version: Int
        params_schema: Opt<Json>
        capabilities: List<Str>
        palette_layer_refs: List<Str>
        # Local path or s3/git URI — adapter-specific
        source_uri: Str
        created_from: Opt<ExtensionLineage>
        created_on: Dt
        updated_on: Dt
        archived: Bool

      val ExtensionVersion
        extension_id: Id
        version: Int
        source_commit: Str
        # target name → artifact URI (local path or s3 key)
        artifact_uris: Json
        published_on: Dt
        published_by: Opt<Id>
        changelog: Opt<Str>

      # Meta registry (create/list/get/versions). Not the object store.
      port ExtensionRegistry
        create!(record: ExtensionRecord) -> ExtensionRecord
        get!(id: Id) -> Opt<ExtensionRecord>
        list!(scope: Opt<Str>, kind: Opt<Str>, product_id: Opt<Str>, tenant_id: Opt<Id>) -> List<ExtensionRecord>
        update!(record: ExtensionRecord) -> ExtensionRecord
        save_version!(ver: ExtensionVersion) -> ExtensionVersion
        get_version!(id: Id, version: Int) -> Opt<ExtensionVersion>
        list_versions!(id: Id) -> List<ExtensionVersion>

      # Package source tree (git-on-S3 later; local dir for dual-loop).
      port ExtensionSourceStore
        ensure_package!(id: Id) -> Str
        write_file!(id: Id, rel_path: Str, content: Str)
        read_file!(id: Id, rel_path: Str) -> Opt<Str>
        list_files!(id: Id, prefix: Str) -> List<Str>
        package_root!(id: Id) -> Str

      # Compiled artifacts (local dir or S3).
      port ExtensionArtifactStore
        put!(id: Id, version: Int, target: Str, data: Bytes) -> Str
        get_uri!(id: Id, version: Int, target: Str) -> Opt<Str>

      # Invoke result for Reactions (EXT-03 ABI).
      enum ExtensionRunStatus
        Succeeded
        Skipped
        Failed

      val ExtensionInvokeResult
        status: ExtensionRunStatus
        message: Opt<Str>
        outputs: Json

      # Firing context passed into invoke (opaque-friendly).
      val ExtensionInvokeRequest
        extension_id: Id
        version: Int
        kind: Str
        params: Json
        context: Json

      # Compile + load + run. Local adapter shells out / loads marker; AWS later.
      port ExtensionExecutor
        publish!(id: Id) -> ExtensionVersion
        invoke!(req: ExtensionInvokeRequest) -> ExtensionInvokeResult

    group application
      # Bus/HTTP services (same pattern as Storage CreateRepo / ListRepos).
      # Host maps HTTP → these services; ports via Deps + local File adapters.

      svc CreateExtension
        -> ExtensionRecord
        input
          name: Str
          kind: Str
          scope: Str
          provenance: Str
          product_id: Opt<Str>
          tenant_id: Opt<Id>
          initiative_id: Opt<Id>
          description: Opt<Str>
          params_schema: Opt<Json>
        step execute
          eid = Id.new()
          now = Dt.now()
          sc = ExtensionScope.Platform
          if scope == "Product"
            sc = ExtensionScope.Product
          if scope == "Tenant"
            sc = ExtensionScope.Tenant
          kd = ExtensionKind.Reaction
          if kind == "Signal"
            kd = ExtensionKind.Signal
          if kind == "Activation"
            kd = ExtensionKind.Activation
          if kind == "UiPanel"
            kd = ExtensionKind.UiPanel
          pv = ExtensionProvenance.Custom
          if provenance == "Stock"
            pv = ExtensionProvenance.Stock
          root = ExtensionSourceStore.ensure_package!(eid)
          rec = ExtensionRecord{extension_id: eid, scope: sc, product_id: product_id, tenant_id: tenant_id, initiative_id: initiative_id, kind: kd, provenance: pv, name: name, description: description, current_version: 0, params_schema: params_schema, capabilities: [], palette_layer_refs: [], source_uri: root, created_from: null, created_on: now, updated_on: now, archived: false}
          saved = ExtensionRegistry.create!(rec)
          ret saved

      svc ListExtensions
        -> List<ExtensionRecord>
        input
          scope: Opt<Str>
          kind: Opt<Str>
          product_id: Opt<Str>
          tenant_id: Opt<Id>
        step execute
          items = ExtensionRegistry.list!(scope, kind, product_id, tenant_id)
          ret items

      svc GetExtension
        -> ExtensionRecord
        input
          id: Id
        step execute
          # Port returns Opt; codegen maps missing → NotFound
          rec = ExtensionRegistry.get!(id)
          ret rec

      svc ListExtensionVersions
        -> List<ExtensionVersion>
        input
          id: Id
        step execute
          items = ExtensionRegistry.list_versions!(id)
          ret items

      svc GetExtensionVersion
        -> ExtensionVersion
        input
          id: Id
          version: Int
        step execute
          ver = ExtensionRegistry.get_version!(id, version)
          ret ver

      svc SaveExtensionVersion
        -> ExtensionVersion
        input
          extension_id: Id
          source_commit: Str
          artifact_uris: Json
          changelog: Opt<Str>
        step execute
          rec = ExtensionRegistry.get!(extension_id)
          next_v = rec.current_version + 1
          rec.current_version = next_v
          rec.updated_on = Dt.now()
          ExtensionRegistry.update!(rec)
          now = Dt.now()
          ver = ExtensionVersion{extension_id: extension_id, version: next_v, source_commit: source_commit, artifact_uris: artifact_uris, published_on: now, published_by: null, changelog: changelog}
          saved = ExtensionRegistry.save_version!(ver)
          ret saved

      # EXT-03: publish = bump integer version + artifact marker (all VEIL)
      svc PublishExtension
        -> ExtensionVersion
        input
          id: Id
        step execute
          rec = ExtensionRegistry.get!(id)
          next_v = rec.current_version + 1
          rec.current_version = next_v
          rec.updated_on = Dt.now()
          ExtensionRegistry.update!(rec)
          uri = ExtensionArtifactStore.put!(id, next_v, "rust.marker", [])
          uris = {}
          now = Dt.now()
          ver = ExtensionVersion{extension_id: id, version: next_v, source_commit: "local", artifact_uris: uris, published_on: now, published_by: null, changelog: null}
          saved = ExtensionRegistry.save_version!(ver)
          ret saved

      svc InvokeExtension
        -> ExtensionInvokeResult
        input
          extension_id: Id
          version: Int
          kind: Str
          params: Json
          context: Json
        step execute
          # Pin check (version record must exist)
          _ver = ExtensionRegistry.get_version!(extension_id, version)
          req = ExtensionInvokeRequest{extension_id: extension_id, version: version, kind: kind, params: params, context: context}
          res = ExtensionExecutor.invoke!(req)
          ret res

      # EXT-08: stock catalog — list then provenance filter is adapter-assisted;
      # product path uses EnsureStockCatalog + ListExtensions with provenance Stock.
      svc ListStockExtensions
        -> List<ExtensionRecord>
        input
          scope: Opt<Str>
          kind: Opt<Str>
          product_id: Opt<Str>
        step execute
          items = ExtensionRegistry.list!(scope, kind, product_id, null)
          ret items

      # EXT-08: upsert one stock package by stable id (idempotent create/update).
      # Host may pass well-known UUIDs; all business fields authored here in VEIL.
      svc UpsertStockExtension
        -> ExtensionRecord
        input
          extension_id: Id
          name: Str
          description: Str
          product_id: Opt<Str>
          params_schema: Opt<Json>
          capabilities: List<Str>
          palette_layer_refs: List<Str>
        step execute
          now = Dt.now()
          root = ExtensionSourceStore.ensure_package!(extension_id)
          rec = ExtensionRecord{extension_id: extension_id, scope: ExtensionScope.Platform, product_id: product_id, tenant_id: null, initiative_id: null, kind: ExtensionKind.Reaction, provenance: ExtensionProvenance.Stock, name: name, description: null, current_version: 1, params_schema: params_schema, capabilities: capabilities, palette_layer_refs: palette_layer_refs, source_uri: root, created_from: null, created_on: now, updated_on: now, archived: false}
          rec.description = Opt.some(description)
          saved = ExtensionRegistry.create!(rec)
          ver = ExtensionVersion{extension_id: extension_id, version: 1, source_commit: "stock-seed", artifact_uris: {}, published_on: now, published_by: null, changelog: null}
          ExtensionRegistry.save_version!(ver)
          ExtensionSourceStore.write_file!(extension_id, "README.md", "stock")
          ret saved

      # EXT-08: ensure platform stock Reactions exist (ids from dual-loop fixture).
      # Bodies inlined (same-context svc-to-svc invoke is not used — all logic stays VEIL).
      svc EnsureStockCatalog
        -> List<ExtensionRecord>
        input
          activate_id: Id
          guard_id: Id
          product_id: Opt<Str>
        step execute
          now = Dt.now()
          root_a = ExtensionSourceStore.ensure_package!(activate_id)
          root_g = ExtensionSourceStore.ensure_package!(guard_id)
          caps_a = ["activation.invoke"]
          caps_g = ["enrollment.is_enrolled"]
          palette = ["reaction_guard", "reaction_activate", "reaction_end"]
          schema_a = {}
          schema_g = {}
          rec_a = ExtensionRecord{extension_id: activate_id, scope: ExtensionScope.Platform, product_id: product_id, tenant_id: null, initiative_id: null, kind: ExtensionKind.Reaction, provenance: ExtensionProvenance.Stock, name: "Activate members", description: Opt.some("Invoke the default Activation for matching members"), current_version: 1, params_schema: Opt.some(schema_a), capabilities: caps_a, palette_layer_refs: palette, source_uri: root_a, created_from: null, created_on: now, updated_on: now, archived: false}
          rec_g = ExtensionRecord{extension_id: guard_id, scope: ExtensionScope.Platform, product_id: product_id, tenant_id: null, initiative_id: null, kind: ExtensionKind.Reaction, provenance: ExtensionProvenance.Stock, name: "Guard then end", description: Opt.some("Skip if not enrolled; otherwise end success"), current_version: 1, params_schema: Opt.some(schema_g), capabilities: caps_g, palette_layer_refs: palette, source_uri: root_g, created_from: null, created_on: now, updated_on: now, archived: false}
          a = ExtensionRegistry.create!(rec_a)
          g = ExtensionRegistry.create!(rec_g)
          ver_a = ExtensionVersion{extension_id: activate_id, version: 1, source_commit: "stock-seed", artifact_uris: {}, published_on: now, published_by: null, changelog: Opt.some("seed")}
          ver_g = ExtensionVersion{extension_id: guard_id, version: 1, source_commit: "stock-seed", artifact_uris: {}, published_on: now, published_by: null, changelog: Opt.some("seed")}
          ExtensionRegistry.save_version!(ver_a)
          ExtensionRegistry.save_version!(ver_g)
          ExtensionSourceStore.write_file!(activate_id, "README.md", "Activate members stock reaction")
          ExtensionSourceStore.write_file!(guard_id, "README.md", "Guard then end stock reaction")
          ret [a, g]

      # EXT-09: duplicate stock → custom with lineage + source file copy
      svc ForkExtension
        -> ExtensionRecord
        input
          source_id: Id
          source_version: Int
          name: Str
          tenant_id: Opt<Id>
          initiative_id: Opt<Id>
        step execute
          src = ExtensionRegistry.get!(source_id)
          eid = Id.new()
          now = Dt.now()
          root = ExtensionSourceStore.ensure_package!(eid)
          lineage = ExtensionLineage{extension_id: source_id, version: source_version}
          rec = ExtensionRecord{extension_id: eid, scope: ExtensionScope.Tenant, product_id: src.product_id, tenant_id: tenant_id, initiative_id: initiative_id, kind: src.kind, provenance: ExtensionProvenance.Custom, name: name, description: src.description, current_version: 0, params_schema: src.params_schema, capabilities: src.capabilities, palette_layer_refs: src.palette_layer_refs, source_uri: root, created_from: Opt.some(lineage), created_on: now, updated_on: now, archived: false}
          saved = ExtensionRegistry.create!(rec)
          # Mark lineage in package tree (full file copy when read returns Str; Opt handled by adapter write of README)
          ExtensionSourceStore.write_file!(eid, "FORK.md", "forked from stock")
          ExtensionSourceStore.write_file!(eid, "README.md", name)
          ret saved

      # EXT-10: list by scope with tenant isolation (tenant_id required when scope=Tenant)
      svc ListExtensionsByScope
        -> List<ExtensionRecord>
        input
          scope: Str
          kind: Opt<Str>
          product_id: Opt<Str>
          tenant_id: Opt<Id>
        step execute
          # Tenant catalogs require tenant_id — empty list if missing (isolation)
          if scope == "Tenant"
            if tenant_id == null
              ret []
          items = ExtensionRegistry.list!(Opt.some(scope), kind, product_id, tenant_id)
          ret items

      # EXT-10: promotion is dev-gated — only Platform scope may write Stock product_id upgrades
      svc PromoteExtension
        -> ExtensionRecord
        input
          extension_id: Id
          target_scope: Str
          allow_promote: Bool
        step execute
          if allow_promote == false
            rec = ExtensionRegistry.get!(extension_id)
            ret rec
          rec = ExtensionRegistry.get!(extension_id)
          if target_scope == "Platform"
            rec.scope = ExtensionScope.Platform
          if target_scope == "Product"
            rec.scope = ExtensionScope.Product
          rec.updated_on = Dt.now()
          saved = ExtensionRegistry.update!(rec)
          ret saved

      # EXT-07: palette gate — allowed node kinds for reaction layer (server-side reject)
      svc ValidateReactionPalette
        -> Bool
        input
          node_kinds: List<Str>
        step execute
          # Allowed only EXT-05 constructs: Guard, Activate, Map, EmitEvent, End
          for k in node_kinds
            ok = false
            if k == "Guard"
              ok = true
            if k == "Activate"
              ok = true
            if k == "Map"
              ok = true
            if k == "EmitEvent"
              ok = true
            if k == "End"
              ok = true
            if k == "guard"
              ok = true
            if k == "activate"
              ok = true
            if k == "map"
              ok = true
            if k == "emit_event"
              ok = true
            if k == "end"
              ok = true
            if ok == false
              ret false
          ret true

      # EXT-12: UI mount ABI (frontend extensions)
      val UiMountRequest
        extension_id: Id
        version: Int
        slot: Str
        props: Json

      val UiMountHandle
        mount_id: Str
        asset_uri: Str

      svc MountUiExtension
        -> UiMountHandle
        input
          extension_id: Id
          version: Int
          slot: Str
          props: Json
        step execute
          uri = f"local://extensions/{slot}/{extension_id}@{version}"
          h = UiMountHandle{mount_id: f"{extension_id}", asset_uri: uri}
          ret h

    group infrastructure
      # ── Extension adapters: VEIL bodies call ExtStore only ─────────────────
      # Permanent fix for "stub lowering": never call raw DdbClient/S3Client from
      # VEIL. AWS SDK lives in runtime/ext_store behind veil_ext_store.stub.
      # Backend: VEIL_EXTENSIONS_BACKEND=file (default) | ddb — same adapter code.
      # Dual-loop host wires File* (extensions_deps). Engine has zero FS/AWS knowledge.

      adapter FileExtensionRegistry for ExtensionRegistry
        @env(VEIL_EXTENSIONS_DIR)
        impl create(record)
          ExtStore.put_record!(self.dir, f"{record.extension_id}", Json.stringify(record))
          ret record
        impl get(id)
          raw = ExtStore.get_record!(self.dir, f"{id}")
          if raw == ""
            ret null
          rec = Json.parse(raw)
          ret rec
        impl list(scope, kind, product_id, tenant_id)
          raws = ExtStore.list_records!(self.dir)
          out = []
          for raw in raws
            rec = Json.parse(raw)
            out = out + [rec]
          ret out
        impl update(record)
          ExtStore.put_record!(self.dir, f"{record.extension_id}", Json.stringify(record))
          ret record
        impl save_version(ver)
          ExtStore.put_version!(self.dir, f"{ver.extension_id}", f"{ver.version}", Json.stringify(ver))
          ret ver
        impl get_version(id, version)
          raw = ExtStore.get_version!(self.dir, f"{id}", f"{version}")
          if raw == ""
            ret null
          ver = Json.parse(raw)
          ret ver
        impl list_versions(id)
          raws = ExtStore.list_versions!(self.dir, f"{id}")
          out = []
          for raw in raws
            ver = Json.parse(raw)
            out = out + [ver]
          ret out

      adapter FileExtensionSourceStore for ExtensionSourceStore
        @env(VEIL_EXTENSIONS_DIR)
        impl ensure_package(id)
          root = ExtStore.ensure_package!(self.dir, f"{id}")
          ret root
        impl write_file(id, rel_path, content)
          ExtStore.write_source!(self.dir, f"{id}", rel_path, content)
          ret Ok
        impl read_file(id, rel_path)
          raw = ExtStore.read_source!(self.dir, f"{id}", rel_path)
          if raw == ""
            ret null
          ret raw
        impl list_files(id, prefix)
          names = ExtStore.list_source!(self.dir, f"{id}")
          ret names
        impl package_root(id)
          ret ExtStore.package_root(self.dir, f"{id}")

      adapter FileExtensionArtifactStore for ExtensionArtifactStore
        @env(VEIL_EXTENSIONS_DIR)
        impl put(id, version, target, data)
          uri = ExtStore.put_artifact!(self.dir, f"{id}", f"{version}", target, "artifact")
          ret uri
        impl get_uri(id, version, target)
          uri = ExtStore.get_artifact_uri!(self.dir, f"{id}", f"{version}", target)
          if uri == ""
            ret null
          ret uri

      # Publish bumps via registry services; invoke succeeds when version exists.
      adapter FileExtensionExecutor for ExtensionExecutor
        @env(VEIL_EXTENSIONS_DIR)
        impl publish(id)
          ver = ExtensionVersion{extension_id: id, version: 1, source_commit: "local", artifact_uris: {}, published_on: Dt.now(), published_by: null, changelog: null}
          ret ver
        impl invoke(req)
          res = ExtensionInvokeResult{status: ExtensionRunStatus.Succeeded, message: null, outputs: {}}
          ret res

      # AWS-named adapters: same ExtStore facade (set VEIL_EXTENSIONS_BACKEND=ddb).
      # No @field(DdbClient/S3Client) — raw SDK calls are never lowered from VEIL.
      adapter DdbExtensionRegistry for ExtensionRegistry
        @env(VEIL_EXTENSIONS_DIR)
        impl create(record)
          ExtStore.put_record!(self.dir, f"{record.extension_id}", Json.stringify(record))
          ret record
        impl get(id)
          raw = ExtStore.get_record!(self.dir, f"{id}")
          if raw == ""
            ret null
          rec = Json.parse(raw)
          ret rec
        impl list(scope, kind, product_id, tenant_id)
          raws = ExtStore.list_records!(self.dir)
          out = []
          for raw in raws
            rec = Json.parse(raw)
            out = out + [rec]
          ret out
        impl update(record)
          ExtStore.put_record!(self.dir, f"{record.extension_id}", Json.stringify(record))
          ret record
        impl save_version(ver)
          ExtStore.put_version!(self.dir, f"{ver.extension_id}", f"{ver.version}", Json.stringify(ver))
          ret ver
        impl get_version(id, version)
          raw = ExtStore.get_version!(self.dir, f"{id}", f"{version}")
          if raw == ""
            ret null
          ver = Json.parse(raw)
          ret ver
        impl list_versions(id)
          raws = ExtStore.list_versions!(self.dir, f"{id}")
          out = []
          for raw in raws
            ver = Json.parse(raw)
            out = out + [ver]
          ret out

      adapter S3ExtensionSourceStore for ExtensionSourceStore
        @env(VEIL_EXTENSIONS_DIR)
        impl ensure_package(id)
          root = ExtStore.ensure_package!(self.dir, f"{id}")
          ret root
        impl write_file(id, rel_path, content)
          ExtStore.write_source!(self.dir, f"{id}", rel_path, content)
          ret Ok
        impl read_file(id, rel_path)
          raw = ExtStore.read_source!(self.dir, f"{id}", rel_path)
          if raw == ""
            ret null
          ret raw
        impl list_files(id, prefix)
          names = ExtStore.list_source!(self.dir, f"{id}")
          ret names
        impl package_root(id)
          ret ExtStore.package_root(self.dir, f"{id}")

      adapter S3ExtensionArtifactStore for ExtensionArtifactStore
        @env(VEIL_EXTENSIONS_DIR)
        impl put(id, version, target, data)
          uri = ExtStore.put_artifact!(self.dir, f"{id}", f"{version}", target, "artifact")
          ret uri
        impl get_uri(id, version, target)
          uri = ExtStore.get_artifact_uri!(self.dir, f"{id}", f"{version}", target)
          if uri == ""
            ret null
          ret uri
