stub aws-sdk-dynamodb 1.116.0
  # Hand-maintained surface for adapter bodies (not full rustdoc dump).
  # AttributeValue + Client wiring used by VEIL adapters; rest of file is stub-gen.
  types_module types
  root_types Client
  cargo_deps aws-config=1.8
  harness_field Client """
{
    let conf = aws_config::load_defaults(aws_config::BehaviorVersion::latest()).await;
    let conf = aws_sdk_dynamodb::config::Builder::from(&conf);
    let conf = if let Ok(ep) = std::env::var("DYNAMO_ENDPOINT").or_else(|_| std::env::var("AWS_ENDPOINT_URL")) {
        conf.endpoint_url(ep).build()
    } else {
        conf.build()
    };
    aws_sdk_dynamodb::Client::from_conf(conf)
}
"""

